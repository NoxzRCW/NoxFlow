{
  "name": "noxflow-monorepo",
  "version": "1.10.8",
  "private": true,
  "description": "Monorepo for NoxFlow diagram editor and library",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "cross-env NODE_ENV=development npm run start --workspace=packages/noxflow-app",
    "dev:win": "cross-env NODE_ENV=development npm run start --workspace=packages/noxflow-app",
    "dev:lib": "npm run dev --workspace=packages/noxflow-lib",
    "dev:backend": "npm run dev --workspace=packages/noxflow-backend",
    "build": "npm run build:lib && npm run build:app",
    "build:lib": "npm run build --workspace=packages/noxflow-lib",
    "build:app": "npm run build --workspace=packages/noxflow-app",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "publish:lib": "npm run build:lib && npm publish --workspace=packages/noxflow-lib",
    "docker:build": "docker build -t noxflow:local .",
    "docker:run": "docker compose -f compose.dev.yml up",
    "update-version": "node scripts/update-version.js",
    "semantic-release": "semantic-release"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "cross-env": "^10.1.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "dom-to-image-more": "^3.7.2"
  },
  "overrides": {
    "lodash": "^4.17.23",
    "lodash-es": "^4.17.23",
    "tar": "^7.5.7"
  }
}
